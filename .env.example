# Supabase Cloud Project Credentials
SUPABASE_URL=https://[YOUR_PROJECT_ID].supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Database (Postgres connection string from Supabase Settings -> Database)
DATABASE_URL=postgres://postgres.[YOUR_PROJECT_ID]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Redis
REDIS_URL=redis://localhost:6379

# AI
ANTHROPIC_API_KEY=your_anthropic_api_key

# External data
FIFA_API_BASE_URL=https://api.fifa.com/v1
FIFA_API_KEY=your_fifa_api_key

# Notifications
FCM_SERVER_KEY=your_fcm_server_key
NTFY_SERVER_URL=http://localhost:2586

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email
SMTP_PASS=your_app_password
